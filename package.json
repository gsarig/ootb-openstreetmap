{
	"name": "ootb-openstreetmap",
	"version": "2.12.0",
	"description": "A map block for the Gutenberg Editor using OpenStreetMaps and Leaflet that needs no API keys and works out of the box.",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start",
		"test:unit": "wp-scripts test-unit-js",
		"postinstall": "cp -r ./node_modules/@raruto/leaflet-gesture-handling/dist/* ./assets/vendor/leaflet-gesture-handling && cp -r ./node_modules/leaflet/dist/* ./assets/vendor/leaflet && cp ./node_modules/leaflet.markercluster/dist/leaflet.markercluster.js ./assets/vendor/leaflet-markercluster/ && cp ./node_modules/leaflet.markercluster/dist/MarkerCluster.css ./assets/vendor/leaflet-markercluster/ && cp ./node_modules/leaflet.markercluster/dist/MarkerCluster.Default.css ./assets/vendor/leaflet-markercluster/"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@wordpress/scripts": "^31.8.0",
		"leaflet.markercluster": "^1.5.3"
	},
	"overrides": {
		"serialize-javascript": "7.0.5",
		"webpack-dev-server": "5.2.3",
		"markdownlint-cli": {
			"minimatch": "3.1.5"
		},
		"@sentry/node": {
			"minimatch": "9.0.9"
		},
		"@typescript-eslint/typescript-estree": {
			"minimatch": "9.0.9"
		}
	},
	"dependencies": {
		"@raruto/leaflet-gesture-handling": "^1.4.4",
		"@wordpress/block-editor": "^15.9.0",
		"leaflet": "^1.9.4",
		"react-device-detect": "^2.2.3",
		"react-leaflet": "^4.2.1"
	}
}
